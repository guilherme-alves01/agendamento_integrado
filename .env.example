PORT=8000
HOST=127.0.0.1
AGENDA_DATA_DIR=

# WhatsApp Cloud API webhook verification token.
WHATSAPP_VERIFY_TOKEN=agenda-bot

# Optional: rephrase factual WhatsApp replies with OpenAI.
# The scheduling flow works without these values.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_POLISH_WHATSAPP=false
